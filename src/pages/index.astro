---
import BaseLayout from "../layouts/BaseLayout.astro";
import hero from "../content/hero.json";
import pricing from "../content/pricing.json";
import features from "../content/features.json";
import gallery from "../content/gallery.json";
import footer from "../content/footer.json";
import header from "../content/header.json";
import mobileHighlights from "../content/mobileHighlights.json";
---

<BaseLayout title="Nail Studio | Manichiură Profesională">
    <a href={`tel:${header.phoneNumber}`} class="mobile-call-btn">
        <i class={header.mobileCall.iconClass}></i>
        {header.mobileCall.text}
    </a>

    <header>
        <nav class="navbar fixed-top custom-navbar">
            <div class="container nav-mobile-row">

                <a class="navbar-brand" href="#">
                    <img src="/img/logo.png" class="logo-img" alt="Your Perfect Nails" />
                </a>

                <ul class="nav-links nav-mobile-links">
                    {header.navLinks.map((link) => (
                            <li class="nav-item">
                                <a class="nav-link" href={link.href}>{link.label}</a>
                            </li>
                    ))}
                </ul>

                <a
                        class="btn btn-primary nav-book-btn"
                        href={`tel:${header.phoneNumber}`}
                >
                    {header.ctaText}
                </a>

            </div>
        </nav>
    </header>

    <main>
        <section class="hero">
            <div class="container hero-container">
                <div class="hero-text">
                    <h1>
                        {hero.titleLine1} <br />
                        {hero.titleLine2}
                        <span class="material-symbols-outlined accent-icon">favorite</span>
                        {hero.titleLine3}
                    </h1>
                    <p>{hero.description}</p>
                </div>

                <div class="search-container">
                    <div class="hero-discovery-container">
                        <a href="#servicesPopup" class="discovery-btn" onclick="event.preventDefault(); location.hash='servicesPopup';">
                            <span>
                              {hero.buttonText}
                                <span class="material-symbols-outlined">
                                {hero.buttonIcon}
                              </span>
                            </span>
                        </a>
                    </div>
                </div>

                <div class="hero-image-wrapper">
                    <img src="img/hero_section_img.png" alt="Nail Art Preview" class="hero-img">
                </div>
            </div>
        </section>

        <section class="mobile-only-highlights">
            <div class="container">
                <div class="mhi-card">
                    {mobileHighlights.items.map((item) => (
                            <div class="mhi-item">
                                <span class="material-symbols-outlined">
                                    {item.icon}
                                </span>
                                <p>{item.text}</p>
                            </div>
                    ))}
                </div>
            </div>
        </section>

        <section id="features" class="features">
            <div class="container">
                <div class="features-header">
                    <h2>{features.sectionTitle}</h2>
                    <p>{features.sectionDescription}</p>
                </div>

                <div class="features-list">
                    {features.items.map((item) => (
                            <div class={`feature-card ${item.brandClass}`}>
                                <div class="feature-text">
                                    <span class="material-symbols-outlined icon">{item.icon}</span>
                                    <h3>{item.title}</h3>
                                    <p>{item.description}</p>
                                </div>

                                <div class="feature-image-placeholder">
                                    <img src={item.image} alt={item.alt} class="feature-img" />
                                </div>
                            </div>
                    ))}
                </div>
            </div>
        </section>

        <section id="portfolio" class="gallery">
            <div class="container">
                <div class="gallery-header">
                    <h2>{gallery.sectionTitle}</h2>
                    <p>{gallery.sectionDescription}</p>
                </div>

                <div class="portfolio-container">
                    <div class="portfolio-slider">
                        {gallery.images.map((img) => (
                                <div class="slide" id={img.id}>
                                    <img src={img.src} alt={img.alt} />
                                </div>
                        ))}
                    </div>

                    <div class="slider-nav">
                        {gallery.images.map((img) => (
                                <a href={`#${img.id}`}></a>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <section id="pricing" class="py-5" style="background:#eeedec; scroll-margin-top:100px;">
            <div class="container">
                <div class="text-center mb-5">
                    <h2 style="font-size:2.5rem; color:#090825;">
                        {pricing.sectionTitle}
                    </h2>
                    <p>{pricing.sectionDescription}</p>
                </div>

                <div class="row g-4">
                    {pricing.categories.map((category) => (
                            <div class="col-12 col-lg-4">
                                <div class="h-100 p-4 rounded-4 text-white"
                                     style={`background:${category.color};`}>
                                    <div class="d-flex align-items-center gap-3 pb-3 mb-4"
                                         style="border-bottom:1px solid rgba(255,255,255,0.18);">
                                      <span class="material-symbols-outlined"
                                              style="font-size:2.5rem;">
                                        {category.icon}
                                      </span>
                                        <h3 class="h5 fw-semibold m-0">{category.title}</h3>
                                    </div>

                                    <ul class="list-unstyled m-0">
                                        {category.services.map((service) => (
                                                <li class="d-flex justify-content-between mb-3">
                                                    <span>{service.name}</span>
                                                    <span class="fw-semibold">{service.price}</span>
                                                </li>
                                        ))}
                                    </ul>
                                </div>
                            </div>
                    ))}
                </div>
            </div>
        </section>

    </main>

    <footer class="main-footer">
        <div class="container footer-grid">
            <div class="footer-column brand-info">
                <a href="#" class="footer-logo-text">
                    <img src="/img/logo_v2.png" alt="logo" />
                </a>
                <p class="brand-tagline">{footer.tagline}</p>
            </div>

            <div class="footer-column">
                <h4>{footer.navTitle}</h4>
                <ul class="footer-nav">
                    {footer.links.map((link) => (
                            <li><a href={link.href}>{link.label}</a></li>
                    ))}
                </ul>
            </div>

            <div class="footer-column">
                <h4>{footer.bookingTitle}</h4>
                <div class="location-info">
                    <span class="material-symbols-outlined">location_on</span>
                    <p>{footer.location}</p>
                </div>
                <a
                        href="#bookingPopup"
                        class="btn-footer btn-book"
                        onclick="event.preventDefault(); location.hash='bookingPopup';"
                >
                    {footer.bookingButtonText}
                </a>
            </div>
        </div>

        <div class="footer-bottom">
            <div class="container">
                <p>{footer.copyright}</p>
            </div>
        </div>
    </footer>

    <div id="bookingPopup" class="popup-overlay">
        <div class="popup-content">
            <a href="javascript:history.back()" class="close-btn">&times;</a>

            <div class="popup-icon">
                <span class="material-symbols-outlined">favorite</span>
            </div>
            <h2>Te așteptăm cu drag!</h2>
            <p>Aștept un apel de la tine pentru a stabili toate detaliile.</p>
            <a href="tel:078949090" class="phone-number">
                <span class="material-symbols-outlined">call</span>
                078949090
            </a>
        </div>
    </div>

    <div id="servicesPopup" class="popup-overlay">
        <div class="popup-content services-content">
            <a href="javascript:history.back()" class="close-btn">&times;</a>

            <div class="popup-icon">
                <span class="material-symbols-outlined">favorite</span>
            </div>

            <h2>Serviciile noastre</h2>

            <div class="services-tags-container">
                <span class="service-tag">Manichiură igienică și îngrijire profesională</span>
                <span class="service-tag">Aplicare ojă semipermanentă sau gel rezistent</span>
                <span class="service-tag">Design personalizat și nail art creativ după plac</span>
                <span class="service-tag">Alungire unghii mărimile 1–5 cu formă perfectă</span>
                <span class="service-tag">Tratament cu parafină și ritual SPA pentru mâini</span>

            </div>

            <div class="interest-section">
                <p>Ți-a stârnit interesul? Programează-te:</p>
                <a href="tel:078949090" class="phone-number">
                    <span class="material-symbols-outlined">call</span>
                    078949090
                </a>
            </div>
        </div>
    </div>

    <!-- The mascot -->
    <div class="mascot" id="mascot">

        <div class="mascot-card">

            <div class="mascot-bubble">
                Salut! Sunt Mihaela ♡<br>
                Te aștept cu drag la mine în salon
            </div>

            <div class="mascot-clip">
                <img class="mascot-frame frame-1" src="img/mascot_initial_position.png" alt="">
                <img class="mascot-frame frame-2" src="img/mascot_second_position.png" alt="">
            </div>

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</BaseLayout>